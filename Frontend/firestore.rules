rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Default deny ────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ─── Users collection ────────────────────────────────────────────────────
    // Any authenticated user can read users (needed for dashboard, role checks)
    // Any authenticated user can create a user document (registration + seeding)
    // Any authenticated user can update any user document (GPS, online status, mission)
    // Only authenticated users can delete (soft restriction for prototype)
    match /users/{userId} {
      allow read, list: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // ─── Pending Approvals ───────────────────────────────────────────────────
    match /pendingUsers/{userId} {
      allow create: if true;
      allow read, list: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // ─── Reports ─────────────────────────────────────────────────────────────
    match /reports/{reportId} {
      allow read, list: if true;
      allow create: if true;
      allow update: if true;
    }

    // ─── Missions ────────────────────────────────────────────────────────────
    match /missions/{missionId} {
      allow read, list: if true;
      allow create: if true;
      allow update: if true;
    }
  }
}
