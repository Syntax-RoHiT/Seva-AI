rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Default deny ────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ─── Users collection ────────────────────────────────────────────────────
    // Any signed-in user can read user profiles (needed for role checks / display)
    // Any signed-in user can create their own profile on registration
    // Users can update their own document (GPS location, online status, missionId etc.)
    // Admins can update any user document (approvals)
    match /users/{userId} {
      allow read, list: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        request.auth.uid == userId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['NGO_ADMIN', 'SUPER_ADMIN', 'GOVERNMENT']
      );
      allow delete: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['NGO_ADMIN', 'SUPER_ADMIN'];
    }

    // ─── Pending Approvals ───────────────────────────────────────────────────
    // Anyone can submit a signup request
    // Any signed-in user can read pending requests (admin check done in-app)
    // Admins can update/delete pending requests
    match /pendingUsers/{userId} {
      allow create: if true;
      allow read, list: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // ─── Reports ─────────────────────────────────────────────────────────────
    // Fully public for emergency reporting & public heatmap
    match /reports/{reportId} {
      allow read, list: if true;
      allow create: if true;
      allow update: if true;
    }

    // ─── Missions ────────────────────────────────────────────────────────────
    // Signed-in users (volunteers + admins) and backend can read/write
    match /missions/{missionId} {
      allow read, list: if true;
      allow create: if true;
      allow update: if true;
    }
  }
}
