rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Common helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isDemo() {
      return isSignedIn() && request.auth.token.firebase.sign_in_provider == 'anonymous';
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && (getUserData().role == role || isDemo());
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // User profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isOwner(userId) || hasRole('NGO_ADMIN') || hasRole('SUPER_ADMIN');
      allow delete: if hasRole('NGO_ADMIN') || hasRole('SUPER_ADMIN');
    }

    // Pending Users
    match /pendingUsers/{userId} {
      allow create: if true; // anyone can sign up
      allow read: if hasRole('NGO_ADMIN') || hasRole('SUPER_ADMIN') || isOwner(userId);
      allow update, delete: if hasRole('NGO_ADMIN') || hasRole('SUPER_ADMIN');
    }

    // Reports - Global visibility for field coordination
    match /reports/{reportId} {
      allow read: if true; 
      allow list: if isSignedIn() || true; // public heatmap allowed to list
      allow create: if true; // Public emergency reporting
      allow update: if isSignedIn() || true; // Server will also update
    }

    // Missions - Strategic deployment access
    match /missions/{missionId} {
      allow read, list: if isSignedIn() || true;
      allow create: if true; // Relaxed for prototype backend
      allow update: if true;
    }

    // Volunteers - GPS tracking
    match /volunteers/{volunteerId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(volunteerId) || hasRole('NGO_ADMIN') || hasRole('SUPER_ADMIN');
      allow delete: if hasRole('NGO_ADMIN') || hasRole('SUPER_ADMIN');
    }
  }
}
