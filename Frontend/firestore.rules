rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Common helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isDemo() {
      return isSignedIn() && request.auth.token.firebase.sign_in_provider == 'anonymous';
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && (getUserData().role == role || isDemo()); // Allow demo users bypass for prototype testing
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // User profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isOwner(userId);
    }

    // Reports - Global visibility for field coordination
    match /reports/{reportId} {
      allow read: if true; // Public oversight
      allow list: if isSignedIn();
      allow create: if true; // Public emergency reporting
      allow update: if isSignedIn() || true; // Relaxed for prototype stabilization
    }

    // Missions - Strategic deployment access
    match /missions/{missionId} {
      allow read, list: if true;
      allow create: if true; // Relaxed for prototype
      allow update: if true;
    }
  }
}
